          'feat.6.tag': 'TV + MT5',
          'int.1.h': 'ÃƒÆ’Ã‚ÂÃƒâ€¹Ã…â€œÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â¶ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â¸ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â» ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â»ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â¾ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â³ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â¸ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Âº',
          'int.1.p': 'Signal, entry, risk map ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â½ÃƒÆ’Ã¢â‚¬ËœÃƒâ€¦Ã¢â‚¬â„¢ live ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â±ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â° backtest-ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â´ ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â¸ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â¶ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â¸ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â» ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â½ÃƒÆ’Ã¢â‚¬Å“Ãƒâ€šÃ‚Â©ÃƒÆ’Ã¢â‚¬ËœÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¦ÃƒÆ’Ã¢â‚¬ËœÃƒÂ¢Ã¢â€šÂ¬Ã‚Â ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â»ÃƒÆ’Ã¢â‚¬Å“Ãƒâ€šÃ‚Â©ÃƒÆ’Ã¢â‚¬Å“Ãƒâ€šÃ‚Â©ÃƒÆ’Ã¢â‚¬ËœÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬ ÃƒÆ’Ã¢â‚¬ËœÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â¾ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â¾ÃƒÆ’Ã¢â‚¬ËœÃƒÂ¢Ã¢â€šÂ¬Ã‚Â ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â¾ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â³ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â´ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â¾ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â½ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â¾.',
          'int.2.h': 'ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â­ÃƒÆ’Ã¢â‚¬ËœÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¦ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â»ÃƒÆ’Ã¢â‚¬ËœÃƒâ€šÃ‚ÂÃƒÆ’Ã¢â‚¬ËœÃƒâ€šÃ‚ÂÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â´ ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚ÂºÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â¾ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â½ÃƒÆ’Ã¢â‚¬ËœÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚ÂµÃƒÆ’Ã‚ÂÃƒâ€šÃ‚ÂºÃƒÆ’Ã¢â‚¬ËœÃƒâ€šÃ‚ÂÃƒÆ’Ã¢â‚¬ËœÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡',
          'int.2.p': 'ÃƒÆ’Ã‚ÂÃƒâ€¦Ã‚Â¡ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â¾ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â½ÃƒÆ’Ã¢â‚¬ËœÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚ÂµÃƒÆ’Ã‚ÂÃƒâ€šÃ‚ÂºÃƒÆ’Ã¢â‚¬ËœÃƒâ€šÃ‚ÂÃƒÆ’Ã¢â‚¬ËœÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡ ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â±ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â° structure ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â±ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â°ÃƒÆ’Ã¢â‚¬ËœÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â»ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â°ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â³ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â´ÃƒÆ’Ã¢â‚¬ËœÃƒâ€šÃ‚ÂÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â°ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â½ÃƒÆ’Ã¢â‚¬ËœÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¹ ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â´ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â°ÃƒÆ’Ã¢â‚¬ËœÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â°ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â° ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â» ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â¾ÃƒÆ’Ã¢â‚¬ËœÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â¾ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â»ÃƒÆ’Ã¢â‚¬ËœÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡ ÃƒÆ’Ã¢â‚¬ËœÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¦ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â¸ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â¹ÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â´ÃƒÆ’Ã¢â‚¬ËœÃƒâ€šÃ‚ÂÃƒÆ’Ã‚ÂÃƒâ€šÃ‚Â³.',
          'nav.pro': 'Pro',
        },
      };

      function setLang(lang, updateUrl = true) {
        const normalized = normalizeLang(lang) || 'en';
        const dict = i18n[normalized] || i18n.en;

        document.documentElement.setAttribute('lang', normalized === 'mn' ? 'mn' : 'en');
        document.querySelectorAll('[data-i18n]').forEach((el) => {
          const key = el.getAttribute('data-i18n');
          if (dict[key] != null) {
            el.innerHTML = dict[key];
            el.removeAttribute('data-i18n-missing');
          } else {
            // Fallback to EN if missing in MN
            const fallback = i18n.en && i18n.en[key] != null ? i18n.en[key] : null;
            if (fallback != null) el.innerHTML = fallback;
            el.setAttribute('data-i18n-missing', '1');
          }
        });

        localStorage.setItem('khan_lang', normalized);

        // Warn once if MN missing keys (helps keep MN/EN in sync)
        try {
          if (normalized === 'mn') {
            const warned = JSON.parse(localStorage.getItem('khan_i18n_warned') || '{}');
            document.querySelectorAll('[data-i18n-missing="1"]').forEach((el) => {
              const k = el.getAttribute('data-i18n');
              if (k && !warned[k]) {
                console.warn('[KHAN i18n] Missing MN key, using EN fallback:', k);
                warned[k] = 1;
              }
            });
            localStorage.setItem('khan_i18n_warned', JSON.stringify(warned));
          }
        } catch (e) {}

        // Reflect language in URL: ?lang=mn / ?lang=en
        if (updateUrl) {
          try {
            const url = new URL(window.location.href);
            url.searchParams.set('lang', normalized);
            window.history.replaceState({}, '', url);
          } catch (e) {
            /* ignore */
          }
        }

        // Button states
        const mnBtn = document.getElementById('langMN');
        const enBtn = document.getElementById('langEN');
        if (mnBtn && enBtn) {
          const activeStyle = 'border-color: rgba(242,193,78,.55); background: rgba(242,193,78,.10)';
          const idleStyle = 'border-color: rgba(255,255,255,.12); background: rgba(255,255,255,.06)';
          mnBtn.style.cssText = normalized === 'mn' ? activeStyle : idleStyle;
          enBtn.style.cssText = normalized === 'en' ? activeStyle : idleStyle;
        }
      }

      document.getElementById('langMN')?.addEventListener('click', () => setLang('mn', true));
      document.getElementById('langEN')?.addEventListener('click', () => setLang('en', true));

      // Init order: URL param > saved preference > default
      const urlLang = normalizeLang(new URLSearchParams(window.location.search).get('lang'));
      const saved = normalizeLang(localStorage.getItem('khan_lang'));
      const initial = urlLang || saved || 'en';
      setLang(initial, urlLang ? false : true);

      document.addEventListener('click', (e) => {
        const target = e.target.closest('[data-track]');
        if (!target) return;
        trackEvent(target.getAttribute('data-track') || 'ui_click', {
          href: target.getAttribute('href') || '',
          id: target.id || '',
        });
      });

      // Wallet quick copy
      const copyWalletBtn = document.getElementById('copyWallet');
      const usdtWalletEl = document.getElementById('usdtWallet');

      async function copyWalletAddress(text) {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(text);
          return true;
        }
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.left = '-9999px';
        document.body.appendChild(ta);
        ta.focus();
        ta.select();
        let ok = false;
        try {
          ok = document.execCommand('copy');
        } catch (e) {
          ok = false;
        }
        ta.remove();
        return ok;
      }

      copyWalletBtn?.addEventListener('click', async () => {
        const address = (usdtWalletEl?.textContent || '').trim();
        if (!address) return;

        const lang = normalizeLang(document.documentElement.getAttribute('lang')) || 'en';
        const dict = i18n[lang] || i18n.en;
        const copyText = dict['usdt.copy'] || i18n.en['usdt.copy'] || 'Copy address';
        const copiedText = dict['usdt.copied'] || i18n.en['usdt.copied'] || 'Copied';

        const ok = await copyWalletAddress(address);
        if (!ok) return;

        copyWalletBtn.textContent = copiedText;
        trackEvent('wallet_copy_success', { wallet: 'usdt_bep20' });
        window.setTimeout(() => {
          copyWalletBtn.textContent = copyText;
        }, 1300);
      });

      // --- Mobile drawer ---
      const drawer = document.getElementById('drawer');
      const burger = document.getElementById('navBurger');
      const closeBtn = document.getElementById('drawerClose');
      const drawerFocusableSelector = 'a[href], button:not([disabled])';
      let drawerRestoreFocusEl = null;

      function getDrawerFocusable() {
        if (!drawer) return [];
        return Array.from(drawer.querySelectorAll(drawerFocusableSelector)).filter((el) => {
          if (!(el instanceof HTMLElement)) return false;
          return !el.hasAttribute('disabled') && el.tabIndex !== -1;
        });
      }

      function handleDrawerKeydown(e) {
        if (!document.body.classList.contains('drawer-open')) return;

        if (e.key === 'Escape') {
          e.preventDefault();
          closeDrawer();
          return;
        }
        if (e.key !== 'Tab') return;

        const focusable = getDrawerFocusable();
        if (!focusable.length) return;
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        const active = document.activeElement;

        if (e.shiftKey && active === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && active === last) {
          e.preventDefault();
          first.focus();
        }
      }

      function openDrawer() {
        drawerRestoreFocusEl = document.activeElement instanceof HTMLElement ? document.activeElement : null;
        document.body.classList.add('drawer-open');
        drawer?.setAttribute('aria-hidden', 'false');
        burger?.setAttribute('aria-expanded', 'true');
        document.addEventListener('keydown', handleDrawerKeydown);
        const focusable = getDrawerFocusable();
        (focusable[0] || closeBtn || burger)?.focus();
      }
      function closeDrawer() {
        document.body.classList.remove('drawer-open');
        drawer?.setAttribute('aria-hidden', 'true');
        burger?.setAttribute('aria-expanded', 'false');
        document.removeEventListener('keydown', handleDrawerKeydown);
        if (drawerRestoreFocusEl && typeof drawerRestoreFocusEl.focus === 'function') {
          drawerRestoreFocusEl.focus();
        }
      }

      burger?.addEventListener('click', () => {
        if (document.body.classList.contains('drawer-open')) closeDrawer();
        else openDrawer();
      });
      closeBtn?.addEventListener('click', closeDrawer);
      drawer?.addEventListener('click', (e) => {
        if (e.target === drawer) closeDrawer();
      });
      window.addEventListener('resize', () => {
        if (window.innerWidth > 980 && document.body.classList.contains('drawer-open')) closeDrawer();
      });
      document.querySelectorAll('.drawer-links a').forEach((a) => a.addEventListener('click', closeDrawer));
      document.getElementById('langMN_m')?.addEventListener('click', () => {
        document.getElementById('langMN')?.click();
        closeDrawer();
      });
      document.getElementById('langEN_m')?.addEventListener('click', () => {
        document.getElementById('langEN')?.click();
        closeDrawer();
      });

      // --- Active section links ---
      const navAnchors = Array.from(document.querySelectorAll('.nav-links a[href^="#"], .drawer-links a[href^="#"]'));
      const navHashes = Array.from(
        new Set(
          navAnchors
            .map((a) => a.getAttribute('href'))
            .filter((href) => href && href.length > 1 && href.startsWith('#')),
        ),
      );
      const navSections = navHashes.map((hash) => document.querySelector(hash)).filter(Boolean);

      function setActiveNav(hash) {
        navAnchors.forEach((a) => {
          const isActive = a.getAttribute('href') === hash;
          a.classList.toggle('is-active', isActive);
          if (isActive) a.setAttribute('aria-current', 'location');
          else a.removeAttribute('aria-current');
        });
      }

      navAnchors.forEach((a) => {
        a.addEventListener('click', () => {
          const hash = a.getAttribute('href');
          if (hash) setActiveNav(hash);
        });
      });

      const initialHash = window.location.hash && navHashes.includes(window.location.hash) ? window.location.hash : '';
      if (initialHash) setActiveNav(initialHash);

      if ('IntersectionObserver' in window && navSections.length) {
        const visibleSections = new Map();
        const navObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              const hash = `#${entry.target.id}`;
              if (entry.isIntersecting) visibleSections.set(hash, entry.intersectionRatio);
              else visibleSections.delete(hash);
            });

            if (!visibleSections.size) return;
            const next = Array.from(visibleSections.entries()).sort((a, b) => b[1] - a[1])[0][0];
            setActiveNav(next);
          },
          {
            rootMargin: '-35% 0px -55% 0px',
            threshold: [0.05, 0.2, 0.4, 0.6],
          },
        );
        navSections.forEach((section) => navObserver.observe(section));
      }

      // --- Reveal animations ---
      const revealTargets = Array.from(document.querySelectorAll('.card, .step, .metric, .cta, .section-head, .chip'));
      revealTargets.forEach((el) => el.classList.add('reveal'));
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((en) => {
              if (en.isIntersecting) {
                en.target.classList.add('in');
                io.unobserve(en.target);
              }
            });
          },
          { threshold: 0.12 },
        );
        revealTargets.forEach((el) => io.observe(el));
      } else {
        revealTargets.forEach((el) => el.classList.add('in'));
      }
    </script>

    <!-- Lightbox -->
    <div class="lightbox" id="lightbox" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Image preview">
      <div class="frame">
        <button class="x" id="lbClose" type="button" aria-label="Close preview">&#10005;</button>
        <img id="lbImg" src="" alt="Preview" />
      </div>
    </div>

    <script>
      // Gallery lightbox (offline-friendly)
      document.addEventListener('DOMContentLoaded', () => {
        const lb = document.getElementById('lightbox');
        const lbImg = document.getElementById('lbImg');
        const closeBtn = document.getElementById('lbClose');
        let lightboxRestoreFocusEl = null;

        const open = (src, triggerEl) => {
          if (!lb || !lbImg) return;
          lightboxRestoreFocusEl = triggerEl instanceof HTMLElement ? triggerEl : document.activeElement;
          lbImg.src = src;
          lb.classList.add('open');
          lb.setAttribute('aria-hidden', 'false');
          closeBtn?.focus();
        };
        const close = () => {
          if (!lb || !lbImg) return;
          lb.classList.remove('open');
          lb.setAttribute('aria-hidden', 'true');
          lbImg.src = '';
          if (lightboxRestoreFocusEl && typeof lightboxRestoreFocusEl.focus === 'function') {
            lightboxRestoreFocusEl.focus();
          }
        };

        // Click any .shot (or children) to open
        document.querySelectorAll('.shot').forEach((card) => {
          if (!(card instanceof HTMLElement)) return;
          card.setAttribute('role', 'button');
          card.setAttribute('tabindex', '0');
          const previewAlt = card.querySelector('img')?.getAttribute('alt');
          if (previewAlt) {
            card.setAttribute('aria-label', `Open ${previewAlt}`);
          }

          const openFromCard = () => {
            const src = card.getAttribute('data-src');
            if (src) open(src, card);
          };

          card.addEventListener('click', openFromCard);
          card.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              openFromCard();
            }
          });
        });

        closeBtn && closeBtn.addEventListener('click', close);
        lb &&
          lb.addEventListener('click', (e) => {
            if (e.target === lb) close();
          });
        window.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') close();
        });
      });
    </script>

    <!-- Scroll to top -->
    <button class="toTop" id="toTop" type="button" aria-label="Scroll to top" title="Top">
      <span>&#8593;</span>
    </button>

    <script>
      // Scroll-to-top button
      document.addEventListener('DOMContentLoaded', () => {
        const toTopBtn = document.getElementById('toTop');
        if (!toTopBtn) return;
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        const toggle = () => {
          const y = window.scrollY || document.documentElement.scrollTop || 0;
          if (y > 520) toTopBtn.classList.add('show');
          else toTopBtn.classList.remove('show');
        };

        toggle();
        window.addEventListener('scroll', toggle, { passive: true });

        toTopBtn.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: prefersReducedMotion ? 'auto' : 'smooth' });
        });
      });
    </script>
  </body>
</html>

