    <!-- HOW IT WORKS -->
    <section id="how">
      <div class="container">
        <div class="section-head">
          <div>
            <div class="pill" data-i18n="how.pill">Process</div>
            <h2 data-i18n="how.h2">A process you can follow every session.</h2>
          </div>
          <p data-i18n="how.p">
            Define direction, wait for structure confirmation, then execute with a pre-mapped risk plan.
          </p>
        </div>

        <div class="steps">
          <div class="step">
            <div class="n" data-i18n="steps.1.n">STEP 01</div>
            <div class="t" data-i18n="steps.1.t">Define HTF direction</div>
            <div class="d" data-i18n="steps.1.d">Set market bias first before looking for entries.</div>
          </div>
          <div class="step">
            <div class="n" data-i18n="steps.2.n">STEP 02</div>
            <div class="t" data-i18n="steps.2.t">Wait for confirmation</div>
            <div class="d" data-i18n="steps.2.d">Enter only after structure confirms.</div>
          </div>
          <div class="step">
            <div class="n" data-i18n="steps.3.n">STEP 03</div>
            <div class="t" data-i18n="steps.3.t">Read liquidity reaction</div>
            <div class="d" data-i18n="steps.3.d">Use sweeps and reactions to filter weak setups.</div>
          </div>
          <div class="step">
            <div class="n" data-i18n="steps.4.n">STEP 04</div>
            <div class="t" data-i18n="steps.4.t">Execute with risk map</div>
            <div class="d" data-i18n="steps.4.d">Each setup includes entry, stop-loss, and targets.</div>
          </div>
        </div>
      </div>
    </section>

