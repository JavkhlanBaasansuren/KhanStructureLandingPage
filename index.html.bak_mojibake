    />

    <!-- Social previews (works online; offline-friendly relative image too) -->
    <meta property="og:title" content="KHAN STRUCTURE ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â Trade With Structure" />
    <meta
      property="og:description"
      content="Context-driven Smart Money Engine. HTF bias alignment. Structure-confirmed execution."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://khanstructure.trade" />
    <meta property="og:image" content="KHAN%20Structure%20-%20Smart%20Money%20Indicator%20cover.png" />
    <meta name="twitter:card" content="summary_large_image" />

    <meta name="theme-color" content="#070A12" />
    <link rel="canonical" href="https://khanstructure.trade" />

    <!-- Offline assets -->
    <link rel="icon" type="image/png" href="khan_logo_transparent.png" />
    <link rel="preload" as="image" href="khan_logo_transparent.png" />
    <link rel="preload" as="image" href="KHAN%20Structure%20-%20Smart%20Money%20Indicator%20cover.png" />

    <title>KHAN STRUCTURE ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â Trade With Structure</title>

    <style>
      :root {
        --bg: #070a12;
        --bg2: #0b0f22;
        --text: rgba(255, 255, 255, 0.92);
        --muted: rgba(255, 255, 255, 0.7);
        --muted2: rgba(255, 255, 255, 0.55);
        --gold: #f2c14e;
        --purple: #7b3ff2;
        --purple2: #b36bff;
        --line: rgba(255, 255, 255, 0.12);
        --shadow: 0 22px 60px rgba(0, 0, 0, 0.45);
        --radius: 20px;
        --radius2: 28px;
        --max: 1120px;
      }

      * {
        box-sizing: border-box;
      }
      html,
      body {
        height: 100%;
        scroll-behavior: smooth;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        margin: 0;
        font-family:
          ui-sans-serif,
          system-ui,
          -apple-system,
          Segoe UI,
          Roboto,
          Helvetica,
          Arial,
          'Apple Color Emoji',
          'Segoe UI Emoji';
        color: var(--text);
        background:
          radial-gradient(1200px 700px at 20% 10%, rgba(123, 63, 242, 0.32), transparent 60%),
          radial-gradient(900px 520px at 90% 20%, rgba(242, 193, 78, 0.16), transparent 55%),
          radial-gradient(900px 520px at 60% 100%, rgba(179, 107, 255, 0.18), transparent 55%),
          linear-gradient(180deg, var(--bg) 0%, var(--bg2) 100%);
        overflow-x: hidden;
        color-scheme: dark;
      }
      a {
        color: inherit;
        text-decoration: none;
      }
      a:focus-visible,
      button:focus-visible,
      .shot:focus-visible {
        outline: 2px solid rgba(242, 193, 78, 0.95);
        outline-offset: 3px;
      }
      .skip-link {
        position: fixed;
        left: 14px;
        top: 10px;
        z-index: 10000;
        transform: translateY(-180%);
        padding: 10px 12px;
        border-radius: 12px;
        border: 1px solid rgba(242, 193, 78, 0.45);
        background: rgba(7, 10, 18, 0.95);
        color: rgba(255, 255, 255, 0.94);
        font-weight: 750;
        transition: transform 0.16s ease;
      }
      .skip-link:focus-visible {
        transform: translateY(0);
      }
      .container {
        max-width: var(--max);
        margin: 0 auto;
        padding: 0 22px;
      }

      /* Top nav */
      .nav {
        position: sticky;
        top: 0;
        z-index: 50;
        backdrop-filter: blur(14px);
        background: linear-gradient(180deg, rgba(7, 10, 18, 0.8) 0%, rgba(7, 10, 18, 0.4) 100%);
        border-bottom: 1px solid var(--line);
      }
      .nav-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 72px;
        gap: 14px;
      }
      .brand {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: unset;
      }
      .brand img {
        height: 38px;
        width: auto;
        display: block;
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 18px;
        font-weight: 600;
        color: var(--muted);
      }
      .nav-links a {
        padding: 9px 8px;
        border-radius: 12px;
        white-space: nowrap;
        border: 1px solid transparent;
        transition:
          background 0.14s ease,
          border-color 0.14s ease,
          color 0.14s ease;
      }
      .nav-links a:hover {
        background: rgba(255, 255, 255, 0.06);
        color: var(--text);
      }
      .nav-links a.is-active,
      .drawer-links a.is-active {
        color: var(--text);
        border-color: rgba(242, 193, 78, 0.34);
        background: rgba(242, 193, 78, 0.12);
      }

      .nav-cta {
        display: flex;
        gap: 8px;
        align-items: center;
        flex-wrap: nowrap;
        white-space: nowrap;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 12px 16px;
        border-radius: 14px;
        font-weight: 700;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(255, 255, 255, 0.06);
        color: var(--text);
        transition:
          transform 0.12s ease,
          background 0.12s ease,
          border-color 0.12s ease;
        user-select: none;
        white-space: nowrap;
      }
      .btn:hover {
        transform: translateY(-1px);
        background: rgba(255, 255, 255, 0.09);
        border-color: rgba(255, 255, 255, 0.18);
      }
      .btn-primary {
        border: 1px solid rgba(242, 193, 78, 0.45);
        background: linear-gradient(180deg, rgba(242, 193, 78, 0.26) 0%, rgba(123, 63, 242, 0.18) 100%);
        box-shadow: 0 16px 40px rgba(123, 63, 242, 0.18);
      }
      .btn-primary:hover {
        border-color: rgba(242, 193, 78, 0.72);
      }

      /* TradingView highlight CTA */
      .btn-tv {
        border: 1px solid rgba(179, 107, 255, 0.55);
        background: linear-gradient(180deg, rgba(179, 107, 255, 0.22) 0%, rgba(242, 193, 78, 0.16) 100%);
        box-shadow: 0 18px 46px rgba(179, 107, 255, 0.18);
      }
      .btn-tv:hover {
        border-color: rgba(179, 107, 255, 0.82);
      }

      .btn-tv .tv-badge {
        font-size: 12px;
        padding: 4px 8px;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.14);
        background: rgba(255, 255, 255, 0.06);
        color: rgba(255, 255, 255, 0.82);
        font-weight: 800;
        letter-spacing: 0.02em;
      }
      .chip {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 8px 12px;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.14);
        background: rgba(255, 255, 255, 0.05);
        color: var(--muted);
        font-weight: 650;
        font-size: 13px;
      }

      /* Hero */
      .hero {
        padding: 56px 0 20px;
        position: relative;
      }
      .hero-grid {
        display: grid;
        grid-template-columns: 1.12fr 0.88fr;
        gap: 24px;
        align-items: stretch;
      }
      .hero-left {
        padding: 26px 0;
      }
      h1 {
        margin: 14px 0 12px;
        font-size: clamp(34px, 4.6vw, 56px);
        letter-spacing: -0.02em;
        line-height: 1.02;
      }
      .gradient-text {
        background: linear-gradient(90deg, var(--gold) 0%, var(--purple2) 55%, rgba(255, 255, 255, 0.92) 100%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }
      .sub {
        font-size: 17px;
        line-height: 1.55;
        color: var(--muted);
        max-width: 62ch;
      }
      .hero-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin: 18px 0 10px;
      }
      .trust {
        display: flex;
        gap: 10px;
        align-items: center;
        margin-top: 14px;
        color: var(--muted2);
        font-weight: 650;
        font-size: 13px;
      }
      .dot {
        width: 8px;
        height: 8px;
        border-radius: 99px;
        background: rgba(242, 193, 78, 0.88);
        box-shadow: 0 0 22px rgba(242, 193, 78, 0.55);
      }

      .hero-right {
        border-radius: var(--radius2);
        overflow: hidden;
        position: relative;
        border: 1px solid rgba(255, 255, 255, 0.12);
        box-shadow: var(--shadow);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.06) 0%, rgba(255, 255, 255, 0.03) 100%);
      }
      .cover {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        filter: saturate(1.05);
        opacity: 0.85;
        transform: scale(1.02);
      }
      .cover-overlay {
        position: absolute;
        inset: 0;
        background:
          radial-gradient(800px 420px at 70% 20%, rgba(242, 193, 78, 0.25), transparent 52%),
          radial-gradient(800px 420px at 20% 30%, rgba(123, 63, 242, 0.28), transparent 55%),
          linear-gradient(180deg, rgba(7, 10, 18, 0.1) 0%, rgba(7, 10, 18, 0.72) 70%, rgba(7, 10, 18, 0.92) 100%);
      }
      .hero-card {
        position: relative;
        height: 420px;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 18px;
        gap: 10px;
      }
      .hero-metrics {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
      }
      .metric {
        padding: 14px 12px;
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(255, 255, 255, 0.06);
      }
      .metric .k {
        font-size: 12px;
        color: var(--muted2);
        font-weight: 700;
      }
      .metric .v {
        margin-top: 6px;
        font-size: 16px;
        font-weight: 800;
      }

      /* Sections */
      section {
        padding: 54px 0;
      }
      section[id] {
        scroll-margin-top: 92px;
      }
      .section-head {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 18px;
      }
      .section-head h2 {
        margin: 0;
        font-size: 28px;
        letter-spacing: -0.02em;
      }
      .section-head p {
        margin: 0;
        color: var(--muted);
        max-width: 70ch;
        line-height: 1.5;
      }
      .grid-3 {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
      }
      .grid-2 {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 14px;
      }

      .card {
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.06) 0%, rgba(255, 255, 255, 0.03) 100%);
        border-radius: var(--radius);
        padding: 18px;
        box-shadow: 0 18px 50px rgba(0, 0, 0, 0.25);
      }
      .card.has-platform-tag {
        position: relative;
        padding-bottom: 44px;
      }
      .card h3 {
        margin: 0 0 8px;
        font-size: 16px;
        letter-spacing: -0.01em;
      }
      .card p {
        margin: 0;
        color: var(--muted);
        line-height: 1.55;
      }
      .pill {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 8px 12px;
        border-radius: 999px;
        border: 1px solid rgba(242, 193, 78, 0.35);
        background: rgba(242, 193, 78, 0.1);
        color: rgba(255, 255, 255, 0.85);
        font-weight: 750;
        font-size: 13px;
        width: fit-content;
        margin-bottom: 10px;
      }
      .icon {
        width: 34px;
        height: 34px;
        border-radius: 12px;
        display: grid;
        place-items: center;
        background: radial-gradient(22px 22px at 30% 30%, rgba(242, 193, 78, 0.35), rgba(123, 63, 242, 0.22));
        border: 1px solid rgba(255, 255, 255, 0.12);
        box-shadow: 0 10px 22px rgba(0, 0, 0, 0.25);
        font-weight: 900;
      }
      .platform-tag {
        position: absolute;
        right: 14px;
        bottom: 12px;
        padding: 5px 10px;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.18);
        background: rgba(6, 12, 26, 0.72);
        color: rgba(255, 255, 255, 0.9);
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }

      /* Steps */
      .steps {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
      }
      .step {
        padding: 16px;
        border-radius: 18px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(255, 255, 255, 0.05);
        min-height: 156px;
        display: flex;
        flex-direction: column;
      }
      .step .n {
        font-size: 12px;
        color: var(--muted2);
        font-weight: 900;
        letter-spacing: 0.08em;
      }
      .step .t {
        margin-top: 8px;
        font-weight: 850;
      }
      .step .d {
        margin-top: 6px;
        color: var(--muted);
        line-height: 1.5;
        font-size: 14px;
      }

      /* Testimonials */
      .testimonial {
        height: 100%;
      }
      .testimonial .rating {
        color: var(--gold);
        font-size: 13px;
        letter-spacing: 0.16em;
        font-weight: 900;
        margin-bottom: 10px;
      }
      .testimonial .q {
        color: var(--text);
        line-height: 1.62;
        font-size: 15px;
      }
      .testimonial .who {
        margin-top: 14px;
        color: var(--muted2);
        font-weight: 760;
        font-size: 13px;
      }
      .list {
        margin: 12px 0 0;
        padding-left: 18px;
        color: var(--muted);
        display: grid;
        gap: 8px;
      }
      .list li {
        line-height: 1.55;
      }

      /* FAQ */
      .faq-item {
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.06) 0%, rgba(255, 255, 255, 0.03) 100%);
        border-radius: var(--radius);
        padding: 14px 16px;
        box-shadow: 0 18px 50px rgba(0, 0, 0, 0.22);
      }
      .faq-item summary {
        cursor: pointer;
        font-weight: 780;
        color: var(--text);
        list-style: none;
        line-height: 1.4;
      }
      .faq-item summary::-webkit-details-marker {
        display: none;
      }
      .faq-item p {
        margin: 10px 0 0;
        color: var(--muted);
        line-height: 1.6;
      }
      .faq-item[open] {
        border-color: rgba(242, 193, 78, 0.3);
        background: linear-gradient(180deg, rgba(242, 193, 78, 0.08) 0%, rgba(255, 255, 255, 0.03) 100%);
      }

      /* Support */
      .link-list {
        display: grid;
        gap: 8px;
        margin-top: 10px;
      }
      .link-list a {
        color: rgba(255, 255, 255, 0.86);
        text-decoration: underline;
        text-underline-offset: 3px;
        line-height: 1.45;
      }
      .warn {
        margin-top: 12px;
        padding: 12px;
        border-radius: 14px;
        border: 1px solid rgba(242, 193, 78, 0.32);
        background: rgba(242, 193, 78, 0.08);
        color: rgba(255, 255, 255, 0.88);
        line-height: 1.5;
        font-size: 14px;
      }
      .support-cta {
        margin-top: 12px;
      }

      /* CTA */
      .cta {
        border-radius: var(--radius2);
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.14);
        background:
          radial-gradient(900px 380px at 20% 30%, rgba(123, 63, 242, 0.28), transparent 60%),
          radial-gradient(900px 380px at 80% 40%, rgba(242, 193, 78, 0.18), transparent 58%),
          linear-gradient(180deg, rgba(255, 255, 255, 0.06) 0%, rgba(255, 255, 255, 0.03) 100%);
        box-shadow: var(--shadow);
      }
      .cta-inner {
        padding: 26px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
      }
      .cta h3 {
        margin: 0;
        font-size: 22px;
        letter-spacing: -0.02em;
      }
      .cta p {
        margin: 8px 0 0;
        color: var(--muted);
        line-height: 1.5;
        max-width: 72ch;
      }

      /* Footer */
      footer {
        padding: 34px 0 52px;
        color: var(--muted2);
      }
      .foot {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 18px;
        flex-wrap: wrap;
        border-top: 1px solid var(--line);
        padding-top: 20px;
      }
      .foot small {
        display: block;
        line-height: 1.5;
      }
      .foot a {
        color: rgba(255, 255, 255, 0.72);
      }
      .foot a:hover {
        color: rgba(255, 255, 255, 0.92);
      }

      /* Mobile drawer */
      .nav-burger {
        display: none;
        padding: 12px 14px;
        font-weight: 900;
      }
      .drawer {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.55);
        backdrop-filter: blur(8px);
        display: none;
        z-index: 200;
      }
      .drawer-panel {
        position: absolute;
        right: 0;
        top: 0;
        height: 100%;
        width: min(420px, 92vw);
        background: linear-gradient(180deg, rgba(7, 10, 18, 0.98) 0%, rgba(11, 15, 34, 0.98) 100%);
        border-left: 1px solid rgba(255, 255, 255, 0.12);
        box-shadow: 0 30px 90px rgba(0, 0, 0, 0.65);
        padding: 18px;
        display: flex;
        flex-direction: column;
        gap: 14px;
      }
      .drawer-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
      }
      .drawer-brand img {
        height: 34px;
        width: auto;
        display: block;
      }
      .drawer-close {
        padding: 12px 14px;
      }
      .drawer-actions {
        display: flex;
        gap: 10px;
      }
      .drawer-links {
        display: flex;
        flex-direction: column;
        gap: 8px;
        padding: 8px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.04);
      }
      .drawer-links a {
        padding: 12px 12px;
        border-radius: 14px;
        color: rgba(255, 255, 255, 0.86);
        font-weight: 800;
        border: 1px solid transparent;
        transition:
          background 0.14s ease,
          border-color 0.14s ease,
          color 0.14s ease;
      }
      .drawer-links a:hover {
        background: rgba(255, 255, 255, 0.06);
      }
      .drawer-cta {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }
      .drawer-note {
        margin-top: auto;
        color: rgba(255, 255, 255, 0.6);
      }
      body.drawer-open {
        overflow: hidden;
      }
      body.drawer-open .drawer {
        display: block;
      }

      /* Subtle premium motion */
      @keyframes glowPulse {
        0%,
        100% {
          filter: drop-shadow(0 0 0 rgba(123, 63, 242, 0));
        }
        50% {
          filter: drop-shadow(0 0 18px rgba(123, 63, 242, 0.26));
        }
      }
      .hero-right {
        animation: glowPulse 6.5s ease-in-out infinite;
      }
      @media (prefers-reduced-motion: reduce) {
        .hero-right {
          animation: none;
        }
      }

      /* Reveal on scroll */
      .reveal {
        opacity: 0;
        transform: translateY(10px);
        transition:
          opacity 0.6s ease,
          transform 0.6s ease;
      }
      .reveal.in {
        opacity: 1;
        transform: none;
      }

      /* Responsive */
      @media (max-width: 980px) {
        .hero-grid {
          grid-template-columns: 1fr;
        }
        .hero-card {
          height: 380px;
        }
        .grid-3 {
          grid-template-columns: 1fr;
        }
        .grid-2 {
          grid-template-columns: 1fr;
        }
        .steps {
          grid-template-columns: 1fr;
        }
        section[id] {
          scroll-margin-top: 84px;
        }
        .nav-links {
          display: none;
        }
        .nav-cta a {
          display: none;
        }
        .nav-burger {
          display: inline-flex;
        }
        .brand {
          min-width: unset;
        }
        .reviews-grid > :nth-child(n + 4) {
          display: none;
        }
      }

      /* Examples gallery */
      .gallery {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
      }
      .shot {
        border-radius: 18px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(255, 255, 255, 0.04);
        box-shadow: 0 18px 50px rgba(0, 0, 0, 0.22);
        cursor: zoom-in;
        position: relative;
      }
      .shot img {
        width: 100%;
        height: auto;
        display: block;
        opacity: 0.96;
        transform: scale(1.01);
      }
      .shot .cap {
        position: absolute;
        left: 12px;
        bottom: 12px;
        right: 12px;
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 10px;
        pointer-events: none;
      }
      .cap .label {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 10px;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.14);
        background: rgba(7, 10, 18, 0.62);
        backdrop-filter: blur(10px);
        color: rgba(255, 255, 255, 0.92);
        font-weight: 850;
        font-size: 13px;
      }
      .cap .note {
        color: rgba(255, 255, 255, 0.74);
        font-weight: 750;
        font-size: 12px;
        text-align: right;
        line-height: 1.25;
        text-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
      }
      /* Lightbox */
      .lightbox {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.72);
        display: none;
        align-items: center;
        justify-content: center;
        padding: 24px;
        z-index: 9999;
      }
      .lightbox.open {
        display: flex;
      }
      .lightbox .frame {
        max-width: min(1200px, 96vw);
        max-height: 92vh;
        border-radius: 18px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.14);
        background: rgba(7, 10, 18, 0.55);
        box-shadow: 0 30px 90px rgba(0, 0, 0, 0.55);
        position: relative;
      }
      .lightbox img {
        width: 100%;
        height: auto;
        display: block;
        max-height: 92vh;
        object-fit: contain;
        background: rgba(0, 0, 0, 0.15);
      }
      .lightbox .x {
        appearance: none;
        padding: 0;
        font: inherit;
        position: absolute;
        top: 10px;
        right: 10px;
        width: 42px;
        height: 42px;
        border-radius: 14px;
        display: grid;
        place-items: center;
        border: 1px solid rgba(255, 255, 255, 0.18);
        background: rgba(255, 255, 255, 0.08);
        color: rgba(255, 255, 255, 0.92);
        font-weight: 900;
        cursor: pointer;
        user-select: none;
      }
      @media (max-width: 980px) {
        .gallery {
          grid-template-columns: 1fr;
        }
        .cap .note {
          text-align: left;
        }
      }

      /* Video */
      .video-card {
        border-radius: var(--radius2);
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.14);
        background:
          radial-gradient(900px 380px at 20% 30%, rgba(123, 63, 242, 0.2), transparent 60%),
          radial-gradient(900px 380px at 80% 40%, rgba(242, 193, 78, 0.14), transparent 58%),
          linear-gradient(180deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.02) 100%);
        box-shadow: var(--shadow);
        padding: 14px;
      }
      .video {
        width: 100%;
        display: block;
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(0, 0, 0, 0.22);
      }
      .video-note {
        margin-top: 10px;
        color: var(--muted2);
        font-weight: 650;
        font-size: 13px;
        line-height: 1.45;
      }

      /* Scroll-to-top */
      .toTop {
        position: fixed;
        right: 18px;
        bottom: 18px;
        z-index: 9998;
        width: 46px;
        height: 46px;
        border-radius: 16px;
        display: grid;
        place-items: center;
        border: 1px solid rgba(255, 255, 255, 0.16);
        background: rgba(7, 10, 18, 0.55);
        backdrop-filter: blur(12px);
        color: rgba(255, 255, 255, 0.92);
        box-shadow: 0 18px 60px rgba(0, 0, 0, 0.45);
        cursor: pointer;
        user-select: none;
        opacity: 0;
        pointer-events: none;
        transform: translateY(10px);
        transition:
          opacity 0.18s ease,
          transform 0.18s ease,
          background 0.18s ease,
          border-color 0.18s ease;
      }
      .toTop:hover {
        background: rgba(255, 255, 255, 0.08);
        border-color: rgba(242, 193, 78, 0.35);
        transform: translateY(6px);
      }
      .toTop.show {
        opacity: 1;
        pointer-events: auto;
        transform: translateY(0);
      }
      .toTop span {
        font-weight: 950;
        font-size: 18px;
        line-height: 1;
      }
      @media (max-width: 980px) {
        .toTop {
          right: 14px;
          bottom: 14px;
        }
      }
    </style>
  </head>
